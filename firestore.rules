rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for "dashboard" collection (laporan)
    match /dashboard/{reportId} {
      allow read, write: if true;
    }

    // Rules for "employees" collection
    match /employees/{employeeId} {
      allow read, write: if true;
    }

    // Rules for "attendance" collection
    match /attendance/{attendanceId} {
      allow read, write: if true;
    }

    // Rules for master data collections
    match /hpi_locations/{id} {
      allow read, write: if true;
    }

    match /hpi_jabatans/{id} {
      allow read, write: if true;
    }

    match /hpi_employee_locations/{id} {
      allow read, write: if true;
    }

    match /hpi_employee_jabatans/{id} {
      allow read, write: if true;
    }

    match /hpi_user_accounts/{id} {
      allow read, write: if true;
    }
  }
}
